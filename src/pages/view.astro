---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Skylog — flight playback</title>

<!-- CesiumJS loader: official CDN first, jsDelivr as fallback. is:inline keeps
     Astro from bundling it, so it runs first and sets window.__cesiumReady
     before the viewer module (which awaits it). See design doc §5.3. -->
<script is:inline>
window.__cesiumReady = new Promise((resolve, reject) => {
  const sources = [
    {
      js:   "https://cesium.com/downloads/cesiumjs/releases/1.126/Build/Cesium/Cesium.js",
      css:  "https://cesium.com/downloads/cesiumjs/releases/1.126/Build/Cesium/Widgets/widgets.css",
      base: "https://cesium.com/downloads/cesiumjs/releases/1.126/Build/Cesium/"
    },
    {
      js:   "https://cdn.jsdelivr.net/npm/cesium@1.126.0/Build/Cesium/Cesium.js",
      css:  "https://cdn.jsdelivr.net/npm/cesium@1.126.0/Build/Cesium/Widgets/widgets.css",
      base: "https://cdn.jsdelivr.net/npm/cesium@1.126.0/Build/Cesium/"
    }
  ];
  (function tryNext(i) {
    if (i >= sources.length) { reject(new Error("All CesiumJS CDN sources failed")); return; }
    const s = sources[i];
    window.CESIUM_BASE_URL = s.base;   // must be set before Cesium.js executes
    const link = document.createElement("link");
    link.rel = "stylesheet"; link.href = s.css;
    document.head.appendChild(link);
    const el = document.createElement("script");
    el.src = s.js;
    el.onload = () => (typeof Cesium !== "undefined") ? resolve() : (el.remove(), link.remove(), tryNext(i + 1));
    el.onerror = () => { el.remove(); link.remove(); tryNext(i + 1); };
    document.head.appendChild(el);
  })(0);
});
</script>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet" />
</head>
<body>

<div id="cesiumContainer"></div>

<!-- Compass: fixed top notch = view direction; the rose's red arrow points to true north -->
<div class="compass" id="compass" title="Camera heading">
  <svg viewBox="0 0 46 46" aria-hidden="true">
    <circle class="compass-ring" cx="23" cy="23" r="21" />
    <polygon class="compass-view" points="23,0 26,5 20,5" />
    <g id="compassRose">
      <polygon class="compass-north" points="23,8 27,23 23,19 19,23" />
      <polygon class="compass-south" points="23,38 27,23 23,27 19,23" />
    </g>
  </svg>
</div>

<!-- Flight card -->
<aside class="flight-card" aria-label="Flight information">
  <p class="eyebrow"><a href="/">← Skylog flights</a></p>
  <h1 id="flightTitle">—</h1>
  <p class="flight-meta" id="flightMeta">—</p>
  <div class="stats">
    <div class="stat"><b id="stDur">—</b><span>Duration</span></div>
    <div class="stat"><b id="stMax">—</b><span>Max alt</span></div>
    <div class="stat"><b id="stClimb">—</b><span>Best climb</span></div>
  </div>
  <div class="desc" id="descWrap" hidden>
    <p class="desc-text clamp" id="flightDesc"></p>
    <button class="desc-toggle" id="descToggle" aria-expanded="false">More</button>
  </div>
</aside>

<!-- Bottom flight strip -->
<div class="strip" role="region" aria-label="Playback controls">
  <div class="controls">
    <button class="btn-play" id="btnPlay" aria-label="Play flight">
      <svg id="icoPlay" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      <svg id="icoPause" viewBox="0 0 24 24" style="display:none"><path d="M6 5h4v14H6zM14 5h4v14h-4z"/></svg>
    </button>
    <div>
      <span class="seg-label">Speed</span>
      <div class="seg" id="speedSeg" role="group" aria-label="Playback speed"></div>
    </div>
  </div>

  <div class="telemetry" aria-label="Live telemetry">
    <div class="cell"><b id="alt">— m</b><span>ALTITUDE</span></div>
    <div class="cell"><b id="spd">— km/h</b><span>GROUND SPD</span></div>
    <div class="cell"><b id="vario">— m/s</b><span>VARIO</span></div>
  </div>

  <div class="profile-wrap">
    <canvas id="profile" aria-label="Altitude profile scrubber"></canvas>
  </div>

  <div class="right-cluster">
    <div>
      <span class="seg-label">Camera</span>
      <div class="seg" id="camSeg" role="group" aria-label="Camera mode">
        <button data-cam="free" aria-pressed="false">Free</button>
        <button data-cam="follow" aria-pressed="true">Follow</button>
      </div>
    </div>
    <div class="clock"><span id="tUTC">—</span><small id="tElapsed">+00:00</small></div>
  </div>
</div>

<div class="toast" id="toast" role="status">
  <span id="toastMsg"></span>
  <button id="toastClose" aria-label="Dismiss">✕</button>
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" role="region" aria-label="Flight photo">
  <button class="lb-close" id="lbClose" aria-label="Close photo">✕</button>
  <div class="lb-frame">
    <img id="lbImg" alt="Flight photo" />
    <div class="lb-strip" id="lbStrip" role="group" aria-label="Photos at this spot"></div>
    <div class="lb-bar">
      <div>
        <div class="lb-caption" id="lbCaption"></div>
        <div class="lb-chips">
          <span class="chip" id="lbSpot"></span>
          <span class="chip" id="lbTime"></span>
          <span class="chip" id="lbAlt"></span>
          <span class="chip" id="lbCount"></span>
        </div>
      </div>
      <div class="lb-nav">
        <button id="lbPrev">← Prev</button>
        <button id="lbNext">Next →</button>
      </div>
    </div>
  </div>
</div>

<!-- Token gate / loading -->
<div class="gate" id="gate">
  <div class="gate-card">
    <div id="gateForm">
      <p class="eyebrow">Skylog · Setup</p>
      <h2>Cesium ion access token</h2>
      <p>This viewer streams <b>Cesium World Terrain</b> and world imagery from Cesium ion.
         Paste a token from your free account at
         <a href="https://ion.cesium.com/tokens" target="_blank" rel="noopener">ion.cesium.com/tokens</a>
         — or set <code>PUBLIC_CESIUM_ION_TOKEN</code> in a <code>.env</code> file.</p>
      <input id="tokenInput" type="text" placeholder="eyJhbGciOi..." autocomplete="off" spellcheck="false" />
      <button class="go" id="btnGo">Load flight</button>
      <p class="gate-err" id="gateErr">That doesn't look like a token. Paste the full string from ion.cesium.com.</p>
    </div>
    <div class="loading" id="gateLoading">
      <div class="ring"></div>
      <p style="color:var(--muted);font-size:13.5px;margin:0">Streaming terrain</p>
    </div>
  </div>
</div>

<!-- Viewer entry (bundled by Astro/Vite from the TypeScript modules) -->
<script>
  import "../viewer/main";
</script>
</body>
</html>
