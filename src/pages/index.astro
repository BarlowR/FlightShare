---
import "../styles/global.css";
import fs from "node:fs";
import path from "node:path";
import { type Activity, ACTIVITIES, ACTIVITY_LABEL, asActivity } from "../shared/activities";

/**
 * Activity gallery. Auto-discovers every bundle under public/flights/<slug>/flight.json
 * at build time and renders a card per flight linking to the viewer. Drop another
 * bundle folder in and it shows up here — no code change.
 */
type Card = {
  slug: string; title: string; date: string; activity: Activity;
  name?: string; gear?: string; location?: string;
  durationMin: number; maxAlt: number; photos: number; thumb: string | null;
};

const FLIGHTS_DIR = path.resolve("public/flights");
let slugs: string[] = [];
try { slugs = fs.readdirSync(FLIGHTS_DIR); } catch { /* no flights dir yet */ }

const flights: Card[] = [];
for (const slug of slugs) {
  // per-flight try/catch: one malformed flight.json is skipped (with a build
  // warning), never blanking the whole gallery
  try {
    const jsonPath = path.join(FLIGHTS_DIR, slug, "flight.json");
    if (!fs.existsSync(jsonPath)) continue;
    const b = JSON.parse(fs.readFileSync(jsonPath, "utf8"));
    const pts: number[][] = b.track?.points ?? [];
    const last = pts.length ? pts[pts.length - 1][0] : 0;
    const maxAlt = pts.reduce((m, p) => Math.max(m, p[3]), 0);
    const photoMedia = (b.media ?? []).filter((m: any) => m.type === "photo");
    const first = photoMedia[0];
    flights.push({
      slug,
      title: b.title || slug,
      date: b.date || "",
      activity: asActivity(b.activity),
      name: b.name ?? b.pilot, gear: b.gear ?? b.glider, location: b.location ?? b.site,
      durationMin: Math.round(last / 60),
      maxAlt: Math.round(maxAlt),
      photos: photoMedia.length,
      // prefer the full-res web rendition for the card cover; the 320px thumb
      // is too small for a 156px-tall cover on hi-DPI screens
      thumb: first ? `/flights/${slug}/${first.web || first.thumb}` : null,
    });
  } catch (e: any) {
    console.warn(`[gallery] skipping ${slug}: ${e.message}`);
  }
}
flights.sort((a, b) => a.title.localeCompare(b.title));

// Group into one section per activity. Every type gets provisioned, but
// sections with no activities are dropped so the menu only shows what's
// actually here. Free Flight leads; the rest keep canonical ACTIVITIES order.
const MENU_ORDER = [...ACTIVITIES].sort((a, b) =>
  Number(b.key === "freeflight") - Number(a.key === "freeflight"));
const sections = MENU_ORDER
  .map((a) => ({ key: a.key, label: a.label, cards: flights.filter((f) => f.activity === a.key) }))
  .filter((s) => s.cards.length > 0);

const fmtDate = (d: string) =>
  d ? new Date(d + "T00:00:00Z").toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric", timeZone: "UTC" }) : "";
const fmtDur = (m: number) => (m >= 60 ? `${Math.floor(m / 60)}h ${m % 60}m` : `${m}m`);

// Dev backdoor: the per-flight Edit links only exist under `astro dev`. In a
// production `astro build` this is statically false, so the links are never
// emitted into the HTML at all.
const DEV = import.meta.env.DEV;
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Peregrination</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;300;400;500&display=swap" rel="stylesheet" />
<style is:global>
  /* the viewer's global.css locks scrolling for the fullscreen globe; the
     gallery scrolls normally */
  html, body { overflow: auto !important; height: auto !important; min-height: 100%; }
</style>
<style>
  .wrap { max-width: 1080px; margin: 0 auto; padding: 48px 24px 64px; }
  header { margin-bottom: 28px; }
  .eyebrow { font-family: var(--font-data); font-size: 11px; letter-spacing: 0.22em; color: var(--accent); text-transform: uppercase; margin: 0 0 8px; }
  h1 { font-size: var(--fs-title); font-weight: 100; margin: 0 0 6px; letter-spacing: 0.01em; }
  .sub { color: var(--muted); font-size: 14px; margin: 0; font-weight: 300; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 18px; margin-top: 28px; }
  /* activity sections: a labelled band per type, only rendered when populated */
  .activity-section { margin-top: 40px; }
  .activity-section .grid { margin-top: 16px; }
  .section-title {
    display: flex; align-items: baseline; gap: 10px;
    font-size: var(--fs-sub); font-weight: 300; margin: 0;
    padding-bottom: 12px; border-bottom: 1px solid var(--line);
  }
  .section-count {
    font-family: var(--font-data); font-size: 12px; letter-spacing: 0.06em;
    color: var(--muted);
  }
  .card {
    display: block; text-decoration: none; color: var(--ink);
    background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius);
    overflow: hidden; transition: border-color 0.15s, transform 0.15s;
  }
  .card:hover { border-color: var(--accent); transform: translateY(-2px); }
  /* "add" tile: same card shape/hover as a flight, dashed accent to read as an action */
  .card-add {
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;
    min-height: 232px; border-style: dashed; border-color: var(--accent);
    color: var(--accent); font-size: 15px; font-weight: 300;
  }
  .card-add .plus { font-size: 34px; font-weight: 100; line-height: 1; }
  .card-add:hover { background: rgba(214, 189, 155, 0.08); }
  .card-wrap { position: relative; }
  /* dev-only edit affordance (the element is only emitted under `astro dev`) */
  .card-edit {
    position: absolute; top: 10px; right: 10px; z-index: 2;
    text-decoration: none; font-size: 12px; color: var(--accent);
    background: var(--panel); border: 1px solid var(--accent); border-radius: 5px;
    padding: 4px 10px; backdrop-filter: blur(6px);
  }
  .card-edit:hover { background: rgba(214, 189, 155, 0.2); }
  .thumb { position: relative; height: 156px; background-color: var(--card-back); background-size: cover; background-position: center; border-bottom: 1px solid var(--line); }
  /* activity type badge, pinned to the thumbnail corner */
  .activity-badge {
    position: absolute; top: 10px; left: 10px;
    font-family: var(--font-data); font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--accent); background: rgba(20, 12, 12, 0.72); backdrop-filter: blur(6px);
    border: 1px solid var(--accent); border-radius: 999px; padding: 3px 10px;
  }
  .card-body { padding: 14px 16px 16px; }
  .card h2 { font-size: var(--fs-sub); font-weight: 300; margin: 0 0 4px; }
  .meta { font-size: 12.5px; color: var(--muted); margin: 0 0 12px; }
  .chips { display: flex; gap: 6px; flex-wrap: wrap; }
  .chip {
    font-family: var(--font-data); font-size: 11px; color: var(--muted);
    border: 1px solid var(--line); border-radius: 999px; padding: 3px 9px; background: var(--panel-soft);
  }
  .empty { color: var(--muted); font-size: 14px; border: 1px dashed var(--line); border-radius: var(--radius); padding: 28px; text-align: center; margin-top: 28px; }
  .empty code { color: var(--accent); }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="head-text">
      <p class="eyebrow">Share the Adventure</p>
      <h1>Peregrination.app</h1>
    </div>
  </header>

  <div class="grid">
    <a class="card card-add" href="/upload">
      <span class="plus">+</span>
      <span>Add Your Activity</span>
    </a>
  </div>

  {sections.map((sec) => (
    <section class="activity-section">
      <h2 class="section-title">{sec.label} <span class="section-count">{sec.cards.length}</span></h2>
      <div class="grid">
        {sec.cards.map((f) => (
          <div class="card-wrap">
            <a class="card" href={`/view?flight=${f.slug}`}>
              <div class="thumb" style={f.thumb ? `background-image:url('${f.thumb}')` : ""}>
                <span class="activity-badge">{ACTIVITY_LABEL[f.activity]}</span>
              </div>
              <div class="card-body">
                <h2>{f.title}</h2>
                <p class="meta">{[fmtDate(f.date), f.name, f.location].filter(Boolean).join(" · ")}</p>
                <div class="chips">
                  <span class="chip">{fmtDur(f.durationMin)}</span>
                  <span class="chip">{f.maxAlt} m</span>
                  <span class="chip">{f.photos} photos</span>
                </div>
              </div>
            </a>
            {DEV && <a class="card-edit" href={`/edit?flight=${f.slug}`}>Edit</a>}
          </div>
        ))}
      </div>
    </section>
  ))}

  {flights.length === 0 && (
    <div class="empty">No activities yet. Add one above, or drop a bundle at <code>public/flights/&lt;slug&gt;/flight.json</code>.</div>
  )}
</div>
</body>
</html>
