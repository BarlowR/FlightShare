---
import "../styles/global.css";
import "../styles/ingest.css";
import NotifyModal from "../components/NotifyModal.astro";

// The "Save to disk" backdoor and loading existing flights are dev-only: this is
// statically false in a production `astro build`, so the button never ships.
const DEV = import.meta.env.DEV;
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Skylog — edit flight</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
<main class="ingest">
  <header>
    <p class="eyebrow"><a href="/">← Skylog flights</a></p>
    <h1>Edit flight</h1>
    <p class="sub" id="sub">Adjust details, captions, and photo timing, then export the flight bundle.</p>
  </header>

  <!-- shown while no flight is loaded -->
  <section class="step" id="loader">
    <h2>Open a flight</h2>
    <p class="note">Continue a draft from a recent upload, or open a <b>flight.json</b> bundle to edit.</p>
    <div class="chips" id="draftList" style="margin-top:16px"></div>
    <div class="actions">
      <label class="drop" id="jsonDrop" style="min-height:80px;flex:1">
        <input type="file" id="jsonInput" accept="application/json,.json" hidden />
        <span>Drop a <b>flight.json</b>, or click to choose</span>
      </label>
    </div>
    <p class="err" id="loadErr" hidden></p>
  </section>

  <!-- editor (hidden until a flight loads) -->
  <div id="editor" hidden>
    <section class="step">
      <h2><span class="idx">1</span>Details</h2>
      <div class="form">
        <label>Title<input type="text" id="fTitle" /></label>
        <label>Date<input type="date" id="fDate" /></label>
        <label>Pilot<input type="text" id="fPilot" /></label>
        <label>Glider<input type="text" id="fGlider" /></label>
        <label>Site<input type="text" id="fSite" /></label>
        <label class="wide">Description<textarea id="fDesc" rows="3"></textarea></label>
      </div>
      <div class="actions">
        <label class="note">Default camera</label>
        <div class="seg" id="camSeg" role="group" aria-label="Default camera">
          <button data-cam="free">Free</button>
          <button data-cam="follow">Follow</button>
        </div>
      </div>
    </section>

    <section class="step" id="photoStep">
      <h2><span class="idx">2</span>Media <span class="note" id="photoCount"></span></h2>
      <p class="note">Photos now — videos and annotations later. Select an item to place it on the track.</p>
      <label class="drop" id="addPhotoDrop" style="min-height:80px;margin-top:14px">
        <input type="file" id="addPhotoInput" accept="image/jpeg,image/png" multiple hidden />
        <span>＋ Add photos — drop <b>JPEG / PNG</b> or click</span>
      </label>
      <div class="add-row">
        <button id="addAnnotation">＋ Add text annotation</button>
      </div>
      <div class="photos" id="photoList"></div>
    </section>

    <section class="step">
      <div class="big-actions">
        <button type="button" class="primary big-btn" data-notify>Save</button>
        <button id="viewBtn" class="big-btn">Open in viewer →</button>
        {DEV && <button id="diskBtn" class="big-btn" title="Write flight.json + media back to the flight's folder">Save to dev</button>}
      </div>
      <p class="note status" id="status"></p>
    </section>
  </div>
</main>

<!-- bottom sheet: scrub a selected media item along the track -->
<div class="scrub-sheet" id="scrubSheet" hidden>
  <div class="scrub-inner">
    <div class="scrub-head">
      <div class="scrub-headtext">
        <textarea class="scrub-title" id="scrubTitle" rows="1" placeholder="Add a caption…"></textarea>
        <div class="scrub-time" id="scrubTime"></div>
      </div>
    </div>
    <div class="scrub-body">
      <img class="scrub-photo" id="scrubPhoto" alt="Selected photo" title="Open full size" />
      <canvas id="planCanvas" aria-label="Top-down track"></canvas>
      <canvas id="altCanvas" aria-label="Altitude profile — drag to set the time"></canvas>
    </div>
    <div class="scrub-foot">
      <button id="scrubReject">Discard</button>
      <span class="spacer"></span>
      <button id="scrubAccept" class="primary">✓ Accept</button>
    </div>
  </div>
</div>

<NotifyModal />

<script>
  import "../ingest/edit-page";
</script>
</body>
</html>
